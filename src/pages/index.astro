<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>实用工具 | Seedtool</title>
    <link rel="stylesheet" href="/styles/tools.css" />
  </head>
  <body>
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <ToolLayout id="rmb-converter" name="人民币大写转换">
          <RmbConverter />
        </ToolLayout>
        <ToolLayout id="abc-converter" name="英文大小写转换">
          <TextCaseConverter />
        </ToolLayout>
        <ToolLayout id="special-char-converter" name="特殊字符检查及转换">
          <SpecialCharTool />
        </ToolLayout>
        <ToolLayout id="number-to-english-converter" name="数字转英文">
          <NumberToWords />
        </ToolLayout>
        <ToolLayout id="pinyin-converter" name="中文转拼音">
          <PinyinConverter />
        </ToolLayout>
      </main>
    </div>
  </body>
</html>

